# L40 / x86_64 (Ada Lovelace). DGX image isnob46/dgx-vllm-cu13 is arm64-only.
FROM vllm/vllm-openai:v0.22.0

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/root/.cache/huggingface \
    UV_PYTHON=3.12 

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl ca-certificates ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app
COPY pyproject.toml uv.lock README.md config/ ./
COPY src/ ./src/

RUN uv python install 3.12 \
    && uv sync --frozen --no-dev

ENV PATH="/app/.venv/bin:/root/.local/bin:${PATH}"

EXPOSE 8787

# vllm-openai base image sets ENTRYPOINT ["vllm", "serve"]; clear it for senserve.
ENTRYPOINT []
CMD ["uv", "run", "senserve"]
